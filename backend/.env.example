# Azure Document Intelligence
AZURE_DOC_INTEL_ENDPOINT=https://<your-doc-intel-resource>.cognitiveservices.azure.com
AZURE_DOC_INTEL_KEY=<your-doc-intel-key>

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://<your-openai-resource>.openai.azure.com
AZURE_OPENAI_KEY=<your-openai-key>
AZURE_OPENAI_DEPLOYMENT=gpt-5.4
AZURE_OPENAI_API_VERSION=2025-03-01-preview

# Azure Language Service (PII)
AZURE_LANGUAGE_ENDPOINT=https://<your-language-resource>.cognitiveservices.azure.com
AZURE_LANGUAGE_KEY=<your-language-key>

# Azure Blob Storage
AZURE_STORAGE_ACCOUNT_URL=https://<your-storage-account>.blob.core.windows.net
AZURE_STORAGE_CONTAINER=redacted-jobs

# Azure Cosmos DB
COSMOS_ENDPOINT=https://<your-cosmos-account>.documents.azure.com:443/
COSMOS_DB_NAME=RedactorDB
COSMOS_KEY=<your-cosmos-key>

# Azure AD / MSAL API validation
AZURE_AD_TENANT_ID=<your-tenant-id>
AZURE_AD_CLIENT_ID=<your-client-id>
ENV=development
DEV_BYPASS=true

# Feature flags
ENABLE_PII_SERVICE=true

# CORS (JSON array)
# pydantic expects complex values (list[str]) to be JSON in the env file.
# Example: ["https://your-site.azurestaticapps.net","http://localhost:5173"]
CORS_ORIGINS=["http://localhost:5173"]

# NOTE: Copy this file to `.env` and replace placeholder values with real secrets.
# Do NOT commit real secrets to version control.
